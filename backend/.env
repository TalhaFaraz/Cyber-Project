# ═══════════════════════════════════════════════════════════════════════════════
#   API KEYS  (status: ✅ real key | 🔄 free fallback | ❌ no key)
# ═══════════════════════════════════════════════════════════════════════════════

# ✅ 1. AbuseIPDB — 1000 checks/day free
ABUSEIPDB_KEY=e982ee5f3224052653b432b72b118314adc46b0003a9bd19ff7e3203075607602d95c3adb9c2ae6f

# ✅ 2. VirusTotal — 500 req/day free
VIRUSTOTAL_KEY=6ae30d47947d1ecd8eda9801780d5256677dd84e1253040835aeb02c6f7a051e

# 🔄 3. Have I Been Pwned — No free key available.
#       We use public breach NAME list (no key needed).
#       Get paid key ($3.50/mo): https://haveibeenpwned.com/API/Key
HIBP_KEY=no_key

# ✅ 4. IPinfo — 50,000 req/month free
IPINFO_KEY=06b8016d1a3b51

# 🔄 5. Shodan — Free tier very limited.
#       We use Shodan InternetDB (100% free, no key needed) as main source.
#       Get key: https://account.shodan.io
SHODAN_KEY=no_key

# 🔄 6. SecurityTrails — Free tier discontinued.
#       Falls back to HackerTarget DNS (free, no key).
#       Get key: https://securitytrails.com/app/signup
SECURITYTRAILS_KEY=no_key

# 🔄 7. WhoisXML — Falls back to RDAP (free, no key needed).
#       Get key: https://www.whoisxmlapi.com/signup
WHOISXML_KEY=no_key

# 🔄 8. GreyNoise — Community API (free, no key needed for basic).
#       Get key: https://www.greynoise.io/
GREYNOISE_KEY=no_key

# 🔄 9. URLScan — Falls back to public search (no key needed).
#       Get key: https://urlscan.io/user/login
URLSCAN_KEY=no_key

# 🔄 10. Hunter.io — Falls back to HackerTarget (free).
#        Get key: https://hunter.io/users/sign_up
HUNTER_KEY=no_key

# 🔄 11. BuiltWith — Uses HackerTarget HTTP headers (free, no key).
BUILTWITH_KEY=no_key

# 🔄 12. Censys — Falls back to Shodan InternetDB (free, no key).
#        Get key: https://search.censys.io/register
CENSYS_API_ID=no_key
CENSYS_SECRET=no_key

# ❌ 13. OpenPhish — NO KEY NEEDED (public feed)

# 🔄 14. AlienVault OTX — Works without key (rate-limited).
#        Get free key: https://otx.alienvault.com/
OTX_KEY=no_key

# ❌ 15. NVD API — NO KEY NEEDED (public NIST endpoint)
NVD_KEY=no_key

# ❌ 16. IPAPI — NO KEY NEEDED (1000 req/day)

# 🔄 17. EmailRep — Works without key (limited).
#        Get free key: https://emailrep.io/key
EMAILREP_KEY=no_key

# ❌ 18. DNS Lookup — NO KEY NEEDED (Google DNS-over-HTTPS)

# 🔄 19. Google Safe Browsing — Falls back to OpenPhish check.
#        Get key: https://console.cloud.google.com
GOOGLE_SAFE_BROWSING_KEY=no_key

# ❌ 20. CVE Details — NO KEY NEEDED (public NVD endpoint)

# ─── CORS ────────────────────────────────────────────────────────────────────
